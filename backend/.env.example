# ============================================================
# InsightFlow BI - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# ---------- Application ----------
APP_NAME=InsightFlow
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---------- Server ----------
HOST=0.0.0.0
PORT=8000

# ---------- Database ----------
# PostgreSQL (production)
DATABASE_URL=postgresql+asyncpg://insightflow:changeme@localhost:5432/insightflow
# SQLite (development fallback)
# DATABASE_URL=sqlite+aiosqlite:///./insightflow.db

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- Security ----------
SECRET_KEY=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- CORS ----------
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ---------- OpenAI / Custom LLM Provider ----------
# Set OPENAI_BASE_URL to https://api.groq.com/openai/v1 to use Groq API key
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=
# Example Groq model: llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# ---------- File Upload ----------
MAX_UPLOAD_SIZE_MB=100
UPLOAD_DIR=./uploads

# ---------- User Data Schema ----------
USER_DATA_SCHEMA=user_data
